NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DATABASE_URL_MIGRATION=postgresql://postgres:postgres@localhost:5432/mirador_core
DATABASE_URL_APP=postgresql://mirador_app:mirador_app_dev@localhost:5432/mirador_core
DATABASE_URL_READONLY=postgresql://mirador_readonly:mirador_readonly_dev@localhost:5432/mirador_core
# openssl rand -hex 32
CORE_SERVICE_TOKEN=change-me-for-local-internal-core
# openssl rand -base64 48 
JWT_SECRET=change-me-for-local-development-only-32chars
SESSION_COOKIE_NAME=mirador_session
SESSION_TTL_SECONDS=86400
CEO_EMAIL=ceo@mirador.local
# Hash argon2 del password del CEO. El valor de abajo corresponde al password
# de desarrollo "mirador-dev-password" y permite login local tras el seed.
# Debe empezar con "$argon2" o el arranque falla la validacion de env.ts.
# Regenerar con: node -e "import('argon2').then(a=>a.default.hash('TU_PASSWORD').then(console.log))"
# En produccion: generar el hash del password real fuera de banda y nunca commitearlo.
CEO_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$pjmW3/dEn4AGbnpUcH6Wfg$9n5wTmLRpffddf9mtxFc2a37NJCTSpabMeASiB3CfCo
ANALYTICS_STATEMENT_TIMEOUT_MS=5000
ANALYTICS_DEFAULT_LIMIT=100
ANALYTICS_MAX_LIMIT=500
# Proveedor LLM del chat orchestrator. "stub" (default) no llama a la red y sirve
# para arrancar sin key. Para usar OpenAI de verdad: LLM_PROVIDER=openai y define
# OPENAI_API_KEY (obligatorio cuando el provider es openai).
LLM_PROVIDER=stub
# OPENAI_API_KEY=sk-...
ORCHESTRATOR_MODEL=gpt-5.2
LIGHT_MODEL=gpt-5-mini
FALLBACK_SQL_ENABLED=true