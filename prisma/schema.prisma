generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CEO
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum InvoiceStatus {
  PAID
  OPEN
  OVERDUE
  VOID
}

enum OpportunityStage {
  PROSPECTING
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  AT_RISK
  COMPLETED
  CANCELED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ExpenseArea {
  ENGINEERING
  SALES
  MARKETING
  SUPPORT
  OPERATIONS
  ADMIN
}

enum ChatRole {
  USER
  ASSISTANT
}

enum ArtifactType {
  TEXT
  TABLE
  KPI
  CHART
  DYNAMIC_CHART
  REPORT
  ACTION_PLAN
}

enum IntentMode {
  RESPONDER
  ANALIZAR
  REPORTE_VISUAL
  PLAN
}

enum ClientType {
  WEB
  MCP
}

enum DocumentStatus {
  PENDING
  INDEXED
  FAILED
}

enum ValidationStatus {
  VALID
  REJECTED
  NOT_APPLICABLE
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique
  role          UserRole       @default(CEO)
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions      Session[]
  conversations Conversation[]

  @@map("users")
}

model Session {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenFamilyId String    @map("token_family_id") @db.Uuid
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenFamilyId])
  @@map("sessions")
}

model Conversation {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?        @map("user_id") @db.Uuid
  title     String?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]
  artifacts ChatArtifact[]

  @@index([userId])
  @@map("conversations")
}

model ChatMessage {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String         @map("conversation_id") @db.Uuid
  role           ChatRole
  intentMode     IntentMode?    @map("intent_mode")
  content        String
  traceId        String         @map("trace_id")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  artifacts      ChatArtifact[]

  @@index([conversationId])
  @@map("chat_messages")
}

model ChatArtifact {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  messageId      String?      @map("message_id") @db.Uuid
  artifactType   ArtifactType @map("artifact_type")
  question       String
  period         String?
  sourceViews    String[]     @map("source_views")
  validatedSql   String?      @map("validated_sql")
  summary        String?
  payload        Json
  chartSpec      Json?        @map("chart_spec")
  freshness      String?
  warnings       String[]
  traceId        String       @map("trace_id")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        ChatMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([messageId])
  @@map("chat_artifacts")
}

model QueryAuditLog {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String?          @map("user_id") @db.Uuid
  clientType               ClientType       @map("client_type")
  path                     String
  question                 String
  metric                   String?
  intentMode               IntentMode?      @map("intent_mode")
  answerSource             String?          @map("answer_source")
  generatedSql             String?          @map("generated_sql")
  validatedSql             String?          @map("validated_sql")
  generatedSqlHash         String?          @map("generated_sql_hash")
  validatedSqlHash         String?          @map("validated_sql_hash")
  validationStatus         ValidationStatus @map("validation_status")
  fallbackReason           String?          @map("fallback_reason")
  missingMetricOrDimension String?          @map("missing_metric_or_dimension")
  sourceViews              String[]         @map("source_views")
  rowCount                 Int?             @map("row_count")
  executionPlan            Json?            @map("execution_plan")
  retrievedDocIds          String[]         @map("retrieved_doc_ids")
  latencyMs                Int?             @map("latency_ms")
  traceId                  String           @map("trace_id")
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([traceId])
  @@map("query_audit_log")
}

model Document {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  sourceUri   String?         @map("source_uri")
  docType     String          @map("doc_type")
  version     String          @default("1")
  contentHash String          @map("content_hash")
  accessScope String          @default("CEO") @map("access_scope")
  status      DocumentStatus  @default(PENDING)
  indexedAt   DateTime?       @map("indexed_at") @db.Timestamptz(6)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  chunks      DocumentChunk[]

  @@index([accessScope])
  @@map("documents")
}

model DocumentChunk {
  id          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId  String                       @map("document_id") @db.Uuid
  chunkIndex  Int                          @map("chunk_index")
  content     String
  tokenCount  Int                          @map("token_count")
  locator     String
  contentHash String                       @map("content_hash")
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  document    Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model Customer {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId    String             @unique @map("external_id")
  name          String
  segment       String
  industry      String
  healthScore   Int                @map("health_score")
  riskLevel     String             @map("risk_level")
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  subscriptions Subscription[]
  invoices      Invoice[]
  opportunities SalesOpportunity[]
  projects      Project[]
  tickets       SupportTicket[]

  @@map("customers")
}

model Subscription {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId    String             @unique @map("external_id")
  customerId    String             @map("customer_id") @db.Uuid
  planName      String             @map("plan_name")
  status        SubscriptionStatus
  monthlyAmount Decimal            @map("monthly_amount") @db.Decimal(12, 2)
  startedAt     DateTime           @map("started_at") @db.Date
  endedAt       DateTime?          @map("ended_at") @db.Date
  customer      Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("subscriptions")
}

model Invoice {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId  String        @unique @map("external_id")
  customerId  String        @map("customer_id") @db.Uuid
  invoiceDate DateTime      @map("invoice_date") @db.Date
  dueDate     DateTime      @map("due_date") @db.Date
  paidAt      DateTime?     @map("paid_at") @db.Date
  amount      Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([invoiceDate])
  @@map("invoices")
}

model SalesOpportunity {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId    String           @unique @map("external_id")
  customerId    String           @map("customer_id") @db.Uuid
  name          String
  stage         OpportunityStage
  amount        Decimal          @db.Decimal(12, 2)
  probability   Int
  expectedClose DateTime         @map("expected_close") @db.Date
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  customer      Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([stage])
  @@map("sales_opportunities")
}

model Project {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId    String        @unique @map("external_id")
  customerId    String        @map("customer_id") @db.Uuid
  name          String
  status        ProjectStatus
  budget        Decimal       @db.Decimal(12, 2)
  estimatedCost Decimal       @map("estimated_cost") @db.Decimal(12, 2)
  startDate     DateTime      @map("start_date") @db.Date
  targetEndDate DateTime      @map("target_end_date") @db.Date
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]

  @@index([customerId])
  @@index([status])
  @@map("projects")
}

model TimeEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId String   @unique @map("external_id")
  projectId  String   @map("project_id") @db.Uuid
  entryDate  DateTime @map("entry_date") @db.Date
  role       String
  hours      Decimal  @db.Decimal(8, 2)
  costRate   Decimal  @map("cost_rate") @db.Decimal(10, 2)
  billRate   Decimal  @map("bill_rate") @db.Decimal(10, 2)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([entryDate])
  @@map("time_entries")
}

model SupportTicket {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId  String         @unique @map("external_id")
  customerId  String         @map("customer_id") @db.Uuid
  openedAt    DateTime       @map("opened_at") @db.Timestamptz(6)
  resolvedAt  DateTime?      @map("resolved_at") @db.Timestamptz(6)
  priority    TicketPriority
  status      TicketStatus
  slaBreached Boolean        @default(false) @map("sla_breached")
  subject     String
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([openedAt])
  @@map("support_tickets")
}

model Expense {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId  String      @unique @map("external_id")
  area        ExpenseArea
  expenseDate DateTime    @map("expense_date") @db.Date
  amount      Decimal     @db.Decimal(12, 2)
  description String

  @@index([expenseDate])
  @@map("expenses")
}
