    {
      "name": "cost_by_area",
      "label": "Cost By Area",
      "description": "Operating costs by business area.",
      "synonyms": ["costos por area", "area costs"],
      "grain": "month",
      "source_view": "ceo_financial_runway",
      "measure": "total_expenses",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "stacked_bar"
    }
