{
  "version": "2026-06-mvp.2",
  "role": "CEO",
  "metrics": [
    {
      "name": "revenue",
      "label": "Ingresos",
      "description": "Ingresos facturados por mes (PAID, OPEN y OVERDUE).",
      "synonyms": [
        "ingresos",
        "ventas",
        "facturacion",
        "facturación",
        "revenue",
        "ingresos totales",
        "ingresos del periodo"
      ],
      "grain": "month",
      "source_view": "ceo_revenue_summary",
      "measure": "revenue",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "customer_revenue",
      "label": "Ingresos por Cliente",
      "description": "Ingresos facturados por cliente y por mes.",
      "synonyms": [
        "ingresos por cliente",
        "ventas por cliente",
        "facturacion por cliente",
        "ingresos de un cliente",
        "revenue por cliente"
      ],
      "grain": "customer_month",
      "source_view": "ceo_customer_revenue",
      "measure": "revenue",
      "dimensions": ["period_month", "customer_name", "segment", "risk_level"],
      "filters_allowed": ["period_month", "customer_name", "segment", "risk_level"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "mrr",
      "label": "MRR",
      "description": "Monthly recurring revenue from active subscriptions.",
      "synonyms": [
        "monthly recurring revenue",
        "revenue mensual recurrente",
        "ingresos recurrentes mensuales"
      ],
      "grain": "month",
      "source_view": "ceo_revenue_summary",
      "measure": "mrr",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "line"
    },
    {
      "name": "arr",
      "label": "ARR",
      "description": "Annualized recurring revenue from current MRR.",
      "synonyms": [
        "annual recurring revenue",
        "revenue anual recurrente",
        "ingresos recurrentes anuales"
      ],
      "grain": "month",
      "source_view": "ceo_revenue_summary",
      "measure": "arr",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "line"
    },
    {
      "name": "mrr_growth",
      "label": "MRR Growth",
      "description": "Period-over-period MRR change computed from revenue summary.",
      "synonyms": ["growth", "crecimiento mrr"],
      "grain": "month",
      "source_view": "ceo_revenue_summary",
      "measure": "mrr",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "percent",
      "default_chart": "line"
    },
    {
      "name": "expansion_revenue",
      "label": "Expansion Revenue",
      "description": "Revenue expansion proxy from increased monthly recurring revenue.",
      "synonyms": ["upsell", "expansion"],
      "grain": "month",
      "source_view": "ceo_revenue_summary",
      "measure": "revenue",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "churn_rate",
      "label": "Churn Rate",
      "description": "Customer churn risk proxy from customer health.",
      "synonyms": ["churn", "cancelaciones"],
      "grain": "customer",
      "source_view": "ceo_customer_health",
      "measure": "health_score",
      "dimensions": ["risk_level", "segment", "industry"],
      "filters_allowed": ["risk_level", "segment", "industry"],
      "time_column": null,
      "format": "percent",
      "default_chart": "bar"
    },
    {
      "name": "at_risk_customers",
      "label": "Customers At Risk",
      "description": "Customers with elevated risk and critical open support tickets.",
      "synonyms": ["clientes en riesgo", "risky customers"],
      "grain": "customer",
      "source_view": "ceo_customer_health",
      "measure": "critical_open_tickets",
      "dimensions": ["customer_name", "risk_level", "segment"],
      "filters_allowed": ["risk_level", "segment", "industry"],
      "time_column": null,
      "format": "integer",
      "default_chart": "table"
    },
    {
      "name": "pipeline_by_stage",
      "label": "Pipeline By Stage",
      "description": "Sales pipeline amount grouped by opportunity stage.",
      "synonyms": ["pipeline", "pipeline por etapa"],
      "grain": "stage",
      "source_view": "ceo_sales_pipeline",
      "measure": "pipeline_amount",
      "dimensions": ["stage"],
      "filters_allowed": ["stage"],
      "time_column": "next_expected_close",
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "close_forecast",
      "label": "Close Forecast",
      "description": "Probability-weighted forecast amount by opportunity stage.",
      "synonyms": ["forecast", "forecast de cierre"],
      "grain": "stage",
      "source_view": "ceo_sales_pipeline",
      "measure": "forecast_amount",
      "dimensions": ["stage"],
      "filters_allowed": ["stage"],
      "time_column": "next_expected_close",
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "projects_at_risk",
      "label": "Projects At Risk",
      "description": "Active delivery risk by project.",
      "synonyms": ["proyectos en riesgo", "delivery risk"],
      "grain": "project",
      "source_view": "ceo_delivery_risk",
      "measure": "hours_logged",
      "dimensions": ["project_name", "customer_name", "delivery_risk", "status"],
      "filters_allowed": ["delivery_risk", "status", "target_end_date"],
      "time_column": "target_end_date",
      "format": "decimal",
      "default_chart": "table"
    },
    {
      "name": "project_margin",
      "label": "Project Margin",
      "description": "Margin amount and percent by project.",
      "synonyms": ["margen", "margen por proyecto"],
      "grain": "project",
      "source_view": "ceo_project_margin",
      "measure": "margin_amount",
      "dimensions": ["project_name", "customer_name", "status"],
      "filters_allowed": ["status", "customer_name"],
      "time_column": null,
      "format": "currency_usd",
      "default_chart": "bar"
    },
    {
      "name": "critical_tickets",
      "label": "Critical Tickets",
      "description": "Critical and high priority support ticket volume.",
      "synonyms": ["tickets criticos", "support critical"],
      "grain": "month",
      "source_view": "ceo_support_health",
      "measure": "ticket_count",
      "dimensions": ["period_month", "priority"],
      "filters_allowed": ["period_month", "priority"],
      "time_column": "period_month",
      "format": "integer",
      "default_chart": "bar"
    },
    {
      "name": "sla_breaches",
      "label": "SLA Breaches",
      "description": "Support SLA breaches by month and priority.",
      "synonyms": ["sla", "brechas sla"],
      "grain": "month",
      "source_view": "ceo_support_health",
      "measure": "breached_sla_count",
      "dimensions": ["period_month", "priority"],
      "filters_allowed": ["period_month", "priority"],
      "time_column": "period_month",
      "format": "integer",
      "default_chart": "bar"
    },
    {
      "name": "burn_rate",
      "label": "Burn Rate",
      "description": "Monthly expense burn rate.",
      "synonyms": ["burn", "gasto mensual"],
      "grain": "month",
      "source_view": "ceo_financial_runway",
      "measure": "total_expenses",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "currency_usd",
      "default_chart": "line"
    },
    {
      "name": "runway",
      "label": "Runway",
      "description": "Estimated runway days from fixed cash baseline and monthly expenses.",
      "synonyms": ["runway", "pista financiera"],
      "grain": "month",
      "source_view": "ceo_financial_runway",
      "measure": "runway_days",
      "dimensions": ["period_month"],
      "filters_allowed": ["period_month"],
      "time_column": "period_month",
      "format": "decimal",
      "default_chart": "line"
