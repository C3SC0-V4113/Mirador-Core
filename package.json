{
  "name": "mirador-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend core for the Mirador CEO analytics system.",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "npm run lint:code && npm run lint:markdown && npm run lint:yaml",
    "lint:code": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:yaml": "yamllint \"**/*.{yml,yaml}\"",
    "format": "prettier . --write",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed/index.ts",
    "knowledge:ingest": "tsx scripts/ingest-knowledge.ts",
    "postinstall": "prisma generate"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pgsql-ast-parser": "^12.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.13",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.22.1",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.6.2",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.13",
    "yaml-lint": "^1.7.0"
  }
}
